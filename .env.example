# Bot mode: advisory | paper | live
BOT_MODE=advisory

# Alpaca Paper API keys (https://app.alpaca.markets)
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Paper trading base URL (use https://api.alpaca.markets for live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Trade knobs
TARGET_PCT=1.0
STOP_PCT=0.5
STAKE_QUOTE=200.0
HORIZON_MINUTES=60
FEE_BUFFER_PCT=0.05
P_MIN=0.35
EDGE_APPROVE=0.05

# Risk caps (USD)
MAX_ORDER_QUOTE=500.0
MAX_POSITION_QUOTE=2000.0
MAX_GROSS_EXPOSURE=5000.0
MAX_DAILY_LOSS_QUOTE=200.0
MAX_DRAWDOWN_PCT=10.0

# Universe / scan
WATCHLIST=SPY,QQQ,IWM,AAPL,MSFT,NVDA,AMD,TSLA,AMZN,META,GOOGL,JPM
MIN_PRICE=5.0
MAX_PRICE=2000.0
MIN_DOLLAR_VOLUME=5000000.0
WS_MAX_SYMBOLS=30
SCAN_INTERVAL_SECONDS=120
PIPELINE_INTERVAL_SECONDS=30

# Paths
DATA_DIR=data
KILL_SWITCH_FILE=data/KILL
LOG_LEVEL=INFO

# Optional Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
